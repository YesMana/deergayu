# Expo public env — copy to `.env` (do not commit secrets beyond public client IDs)

# Firebase Google Sign-In → Web client ID
# Firebase Console → Authentication → Sign-in method → Google → Web SDK configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional API override (default: Render)
# EXPO_PUBLIC_API_URL=https://deergayu-api.onrender.com
