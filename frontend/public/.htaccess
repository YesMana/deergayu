<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Do not rewrite API requests (let Node.js/Passenger handle them)
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^ - [L]
  
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
